@model MecanicosReportViewModel
@{
    Layout = null;
    var listaPeriodos = ViewBag.TodosLosPeriodos as List<StjacksAssistens.Models.Periodss>;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Reporte Ausentismo - @Model.Periodo.Description</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/spreadssheet.css" />
    <style>
        /* Estilos para el buscador dinámico */
        .search-results-container {
            position: absolute;
            width: 100%;
            z-index: 1000;
            background: white;
            border: 1px solid #dee2e6;
            border-radius: 0 0 5px 5px;
            max-height: 300px;
            overflow-y: auto;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .search-item {
            padding: 10px;
            cursor: pointer;
            border-bottom: 1px solid #f8f9fa;
            transition: background 0.2s;
        }

            .search-item:hover {
                background-color: #f1f3f5;
            }

        .editable-motivo {
            min-height: 25px;
            outline: none;
            padding: 2px;
        }

            .editable-motivo.saving {
                background-color: #fff3cd;
                opacity: 0.7;
            }

        @@media print {
            .no-print {
                display: none !important;
            }
        }
    </style>
</head>
<body class="p-4 bg-white">

    @* Panel de Filtros y Búsqueda *@
    <div class="no-print p-3 mb-4 shadow-sm rounded border bg-light">
        <div class="row align-items-center">
            <div class="col-md-5 position-relative">
                <label class="fw-bold small text-muted"><i class="bi bi-search"></i> Digite fecha o nombre del periodo:</label>
                <input type="text" id="periodSearchInput" class="form-control form-control-sm"
                       placeholder="Ej: 2026 o Catorcena..." autocomplete="off">

                <div id="periodSearchResults" class="search-results-container" style="display: none;">
                    @foreach (var p in listaPeriodos)
                    {
                        <div class="search-item"
                             data-id="@p.Id"
                             data-filter="@p.Description.ToLower() @p.StartDate.ToString("dd/MM/yyyy") @p.EndDate.ToString("dd/MM/yyyy")">
                            <strong>@p.Description</strong><br>
                            <span class="text-muted small">Rango: @p.StartDate.ToShortDateString() - @p.EndDate.ToShortDateString()</span>
                        </div>
                    }
                </div>
            </div>
            <div class="col-md-7 text-end">
                <button onclick="window.print()" class="btn btn-dark btn-sm">
                    <i class="bi bi-printer"></i> Imprimir Documento
                </button>
                <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left"></i> Regresar
                </a>
            </div>
        </div>
    </div>

    @* Encabezado del Reporte *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span class="fw-bold" style="font-size: 14px;">INDUSTRIAS ST. JACK'S S.A. DE C.V.</span>
        <span class="fw-bold text-decoration-underline" style="font-size: 16px;">REPORTE DE AUSENTISMO</span>
    </div>

    <table class="table-excel mb-3">
        <tr class="header-purple">
            <td style="width: 10%;">CDC</td>
            <td style="width: 40%;">Nombre del Área, Depto. o Gerencia</td>
            <td style="width: 20%;">Tipo de Planilla</td>
            <td style="width: 30%;">Período de Pago</td>
        </tr>
        <tr>
            <td>409</td>
            <td>MANTENIMIENTO (MECÁNICOS)</td>
            <td>14 Días (Catorcenal)</td>
            <td class="fw-bold">Del @Model.Periodo.StartDate.ToString("dd/MM/yyyy") al @Model.Periodo.EndDate.ToString("dd/MM/yyyy")</td>
        </tr>
    </table>

    @* Tabla Principal *@
    <table class="table-excel">
        <thead>
            <tr class="header-purple">
                <th rowspan="2" style="width: 30px;">No.</th>
                <th rowspan="2" style="width: 60px;">Código</th>
                <th rowspan="2">Nombre del Empleado</th>
                <th colspan="5">Días de la Semana</th>
                <th rowspan="2">Motivo de la Ausencia / Observaciones</th>
            </tr>
            <tr class="header-purple">
                <th style="width: 80px;">Lunes</th>
                <th style="width: 80px;">Martes</th>
                <th style="width: 80px;">Miércoles</th>
                <th style="width: 80px;">Jueves</th>
                <th style="width: 80px;">Viernes</th>
            </tr>
        </thead>
        <tbody>
            @{
                int count = 1;
                var empleadosConAusencias = Model.Empleados.Where(emp =>
                emp.Semanas.Any(s =>
                s.Lunes.HasValue || s.Martes.HasValue || s.Miercoles.HasValue || s.Jueves.HasValue || s.Viernes.HasValue
                )).ToList();
            }

            @if (!empleadosConAusencias.Any())
            {
                <tr>
                    <td colspan="9" class="text-center py-4 text-muted">
                        <i class="bi bi-info-circle"></i> No se encontraron registros de ausencias en este periodo.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var emp in empleadosConAusencias)
                {
                    var sem1 = emp.Semanas.ElementAtOrDefault(0);
                    var sem2 = emp.Semanas.ElementAtOrDefault(1);

                    <!-- Primera Fila (Semana 1) -->
                    <tr>
                        <td rowspan="2">@count</td>
                        <td rowspan="2" class="fw-bold">@emp.Codigo</td>
                        <td rowspan="2" class="text-start ps-2">@emp.Nombre</td>

                        <td>@(sem1?.Lunes?.ToString("dd-MMM") ?? "")</td>
                        <td>@(sem1?.Martes?.ToString("dd-MMM") ?? "")</td>
                        <td>@(sem1?.Miercoles?.ToString("dd-MMM") ?? "")</td>
                        <td>@(sem1?.Jueves?.ToString("dd-MMM") ?? "")</td>
                        <td>@(sem1?.Viernes?.ToString("dd-MMM") ?? "")</td>

                        <td class="text-start small italic p-1">
                            <div class="editable-motivo" contenteditable="true"
                                 data-opid="@emp.Codigo" data-period="@Model.Periodo.Id"
                                 onblur="saveObservation(this)">
                                @(sem1?.Motivo ?? "")
                            </div>
                        </td>
                    </tr>

                    <!-- Segunda Fila (Semana 2) -->
                    <tr>
                        <td>@(sem2?.Lunes?.ToString("dd-MMM") ?? "")</td>
                        <td>@(sem2?.Martes?.ToString("dd-MMM") ?? "")</td>
                        <td>@(sem2?.Miercoles?.ToString("dd-MMM") ?? "")</td>
                        <td>@(sem2?.Jueves?.ToString("dd-MMM") ?? "")</td>
                        <td>@(sem2?.Viernes?.ToString("dd-MMM") ?? "")</td>

                        <td class="text-start small italic p-1">
                            <div class="editable-motivo" contenteditable="true"
                                 data-opid="@emp.Codigo" data-period="@Model.Periodo.Id"
                                 onblur="saveObservation(this)">
                                @(sem2?.Motivo ?? "")
                            </div>
                        </td>
                    </tr>
                    count++;
                }
            }
        </tbody>
    </table>

    @* Sección de Firmas *@
    <div class="container-fluid text-center mt-5">
        <div class="row">
            <div class="col-4">
                <div style="border-top: 1px solid black; width: 80%; margin: 0 auto;"></div>
                <div class="fw-bold small">Elaborado por:</div>
                <div class="small">Digitador de Planilla</div>
            </div>
            <div class="col-4">
                <div style="border-top: 1px solid black; width: 80%; margin: 0 auto;"></div>
                <div class="fw-bold small">Revisado por:</div>
                <div class="small">Jefe de Mantenimiento</div>
            </div>
            <div class="col-4">
                <div style="border-top: 1px solid black; width: 80%; margin: 0 auto;"></div>
                <div class="fw-bold small">Autorizado por:</div>
                <div class="small">Recursos Humanos</div>
            </div>
        </div>
    </div>

    <script>
        // --- LÓGICA DE BÚSQUEDA ---
        const input = document.getElementById('periodSearchInput');
        const container = document.getElementById('periodSearchResults');
        const allItems = document.querySelectorAll('.search-item');

        input.addEventListener('input', function() {
            const searchText = this.value.toLowerCase().trim();

            if (searchText.length === 0) {
                container.style.display = 'none';
                return;
            }

            let foundCount = 0;
            allItems.forEach(item => {
                const itemData = item.getAttribute('data-filter');
                if (itemData.includes(searchText)) {
                    item.style.display = 'block';
                    foundCount++;
                } else {
                    item.style.display = 'none';
                }
            });

            container.style.display = foundCount > 0 ? 'block' : 'none';
        });

        // Click en un resultado
        allItems.forEach(item => {
            item.addEventListener('click', function() {
                const id = this.getAttribute('data-id');
                window.location.href = '/Ausentismo/ReporteMecanicos?periodId=' + id;
            });
        });

        // Cerrar al hacer click fuera
        document.addEventListener('click', function(e) {
            if (!input.contains(e.target) && !container.contains(e.target)) {
                container.style.display = 'none';
            }
        });

        // --- GUARDADO DE OBSERVACIONES ---
        function saveObservation(element) {
            const text = element.innerText.trim();
            const opCode = element.getAttribute('data-opid');
            const pId = element.getAttribute('data-period');

            element.classList.add('saving');

            fetch('/Ausentismo/GuardarObservacion', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    OperatorCode: opCode,
                    PeriodId: parseInt(pId),
                    Observation: text
                })
            })
            .then(response => {
                element.classList.remove('saving');
                if(!response.ok) {
                    alert("Error al guardar los cambios.");
                }
            })
            .catch(error => {
                console.error("Error:", error);
                element.classList.remove('saving');
            });
        }
    </script>
</body>
</html>