@{
    ViewData["Title"] = "Panel de Control Pro";
}
<link rel="stylesheet" href="~/css/menuPrincipal.css" />
<style>
    :root {
        --st-primary: #4361ee;
        --st-secondary: #7209b7;
        --st-success: #4cc9f0;
        --st-bg: #f8f9fa;
    }

    .dashboard-container {
        background: var(--st-bg);
        min-height: 100vh;
        padding: 2rem 1rem;
    }
    .premium-card {
        background: #ffffff;
        border: none;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
        transition: all 0.3s ease;
    }

        .premium-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(67, 97, 238, 0.1);
        }

    .icon-shape {
        width: 55px;
        height: 55px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 1rem;
        font-size: 1.5rem;
    }
    .chart-wrapper {
        height: 350px;
        width: 100%;
    }
    .alert-indicator {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 8px;
    }
    .bg-grad-primary {
        background: linear-gradient(135deg, #4361ee, #4895ef);
    }

    .bg-grad-success {
        background: linear-gradient(135deg, #2ec4b6, #cbf3f0);
    }

    .bg-grad-warning {
        background: linear-gradient(135deg, #ff9f1c, #ffbf69);
    }

    .quick-action-btn {
        border-radius: 1rem;
        padding: 1rem;
        text-align: center;
        border: 1px solid rgba(0,0,0,0.05);
        background: white;
        transition: 0.2s;
    }

        .quick-action-btn:hover {
            background: var(--st-primary);
            color: white !important;
        }
</style>

<div class="dashboard-container">
    <div class="row mb-4 align-items-end">
        <div class="col-md-7">
            <span class="badge bg-primary-soft text-primary px-3 py-2 rounded-pill mb-2">Sistema v2.0.1</span>
            <h1 class="fw-bold display-6 mb-1">St. Jacks <span class="text-primary"> </span></h1>
            <p class="text-muted">Análisis de rendimiento y control de personal en tiempo real.</p>
        </div>
        <div class="col-md-5 text-md-end">
            <div class="premium-card d-inline-flex align-items-center p-3 shadow-sm">
                <div class="me-3 text-end">
                    <div id="current-time" class="h4 fw-bold mb-0 text-primary"></div>
                    <div class="small text-muted">@DateTime.Now.ToString("dd 'de' MMMM, yyyy")</div>
                </div>
                <div class="icon-shape bg-light text-primary border"><i class="bi bi-clock-history"></i></div>
            </div>
        </div>
    </div>
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card premium-card p-4">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted small fw-bold">TOTAL OPERARIOS</h6>
                        <h2 class="fw-bold mb-0">128</h2>
                        <span class="text-success small fw-bold"><i class="bi bi-arrow-up"></i> 4% mes actual</span>
                    </div>
                    <div class="icon-shape bg-grad-primary text-white shadow-sm"><i class="bi bi-people"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card premium-card p-4">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted small fw-bold">AUSENTISMO</h6>
                        <h2 class="fw-bold mb-0">94.2%</h2>
                        <span class="text-primary small fw-bold">121/128 presentes</span>
                    </div>
                    <div class="icon-shape bg-grad-success text-white shadow-sm"><i class="bi bi-calendar2-check"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card premium-card p-4">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted small fw-bold">INCAPACIDADES</h6>
                        <h2 class="fw-bold mb-0">3</h2>
                        <span class="text-danger small fw-bold">Pendientes de revisión</span>
                    </div>
                    <div class="icon-shape bg-grad-warning text-white shadow-sm"><i class="bi bi-bandaid"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <a asp-controller="Spreadsheet" asp-action="Index" class="card premium-card p-4 text-decoration-none shadow-sm h-100">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted small fw-bold">GESTIÓN DE PAGOS</h6>
                        <h2 class="fw-bold mb-0 text-dark">Planilla</h2>
                        <span class="text-primary small fw-bold">Ir a cálculos <i class="bi bi-arrow-right-short"></i></span>
                    </div>
                    <div class="icon-shape bg-light text-success border" style="background-color: #e8f5e9 !important; border-color: #c8e6c9 !important;">
                        <i class="bi bi-cash-stack"></i>
                    </div>
                </div>
            </a>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card premium-card p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold m-0"><i class="bi bi-graph-up me-2"></i>Productividad Semanal</h5>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-light border dropdown-toggle" data-bs-toggle="dropdown">Últimos 15 días</button>
                    </div>
                </div>
                <div class="chart-wrapper">
                    <canvas id="mainDashboardChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card premium-card p-4 h-100">
                <h5 class="fw-bold mb-4">Alertas Recientes</h5>
                <div class="list-group list-group-flush">
                    <div class="list-group-item bg-transparent border-0 px-0 mb-3">
                        <div class="d-flex align-items-center">
                            <div class="icon-shape bg-light-danger text-danger me-3" style="width:45px; height:45px; font-size:1rem;">
                                <i class="bi bi-exclamation-triangle"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold small">Ausencia Injustificada</h6>
                                <p class="text-muted small mb-0">Operario: Juan Pérez (OP-442)</p>
                            </div>
                        </div>
                    </div>
                    <div class="list-group-item bg-transparent border-0 px-0 mb-3">
                        <div class="d-flex align-items-center">
                            <div class="icon-shape bg-light-info text-info me-3" style="width:45px; height:45px; font-size:1rem;">
                                <i class="bi bi-info-circle"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold small">Nuevo Periodo Creado</h6>
                                <p class="text-muted small mb-0">Abril Q2 ha sido iniciado.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <hr>
                <h6 class="fw-bold mb-3">Acciones Rápidas</h6>
                <div class="row g-2">
                    <div class="col-6">
                        <a asp-controller="Operators" asp-action="Index" class="quick-action-btn d-block text-decoration-none text-dark small fw-bold">
                            <i class="bi bi-table d-block fs-4 mb-1"></i> Asistencia
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="#" class="quick-action-btn d-block text-decoration-none text-dark small fw-bold">
                            <i class="bi bi-file-earmark-pdf d-block fs-4 mb-1"></i> Reportes
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function updateClock() {
            const now = new Date();
            document.getElementById('current-time').innerText = now.toLocaleTimeString('es-SV', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
        setInterval(updateClock, 1000);
        updateClock();
        const ctx = document.getElementById('mainDashboardChart').getContext('2d');
        const primaryColor = '#4361ee';
        const secondaryColor = '#4cc9f0';
        const fillGradient = ctx.createLinearGradient(0, 0, 0, 300);
        fillGradient.addColorStop(0, 'rgba(67, 97, 238, 0.2)');
        fillGradient.addColorStop(1, 'rgba(67, 97, 238, 0)');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['01 Abr', '02 Abr', '03 Abr', '04 Abr', '05 Abr', '08 Abr', '09 Abr', '10 Abr'],
                datasets: [{
                    label: 'Tasa de Asistencia',
                    data: [95, 93, 98, 92, 95, 96, 94, 97],
                    borderColor: primaryColor,
                    backgroundColor: fillGradient,
                    fill: true,
                    tension: 0.4,
                    borderWidth: 4,
                    pointRadius: 5,
                    pointHoverRadius: 8,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: primaryColor,
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: false,
                        min: 85,
                        grid: { borderDash: [5,5], color: '#e2e8f0' },
                        ticks: { callback: v => v + '%' }
                    },
                    x: { grid: { display: false } }
                }
            }
        });
    </script>
}