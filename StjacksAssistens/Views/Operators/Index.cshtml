@model StjacksAssistens.Models.AttendanceViewModel
@{
    ViewData["Title"] = "Asistencia";
}

<link rel="stylesheet" href="~/css/operators.css" />

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Control de Asistencia</h1>
    <div>
        <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#createPeriodModal">
            Nuevo Periodo
        </button>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createOperatorModal">
            Nuevo Operario
        </button>
    </div>
</div>

@* Navegación de Periodos (Pestañas superiores para que no estorben) *@
<div class="mb-4">
    <ul class="nav nav-tabs">
        @foreach (var p in (List<StjacksAssistens.Models.Periodss>)ViewBag.AllPeriods)
        {
            <li class="nav-item">
                <a asp-action="Index" asp-route-periodId="@p.Id"
                   class="nav-link @(Model.CurrentPeriod.Id == p.Id ? "active fw-bold" : "")">
                    @p.Description
                </a>
            </li>
        }
    </ul>
</div>

@* Filtros de Categoría *@
<div class="mb-3">
    <div class="btn-group" role="group">
        <a asp-action="Index" asp-route-periodId="@Model.CurrentPeriod.Id" class="btn btn-outline-primary @(ViewBag.SelectedCategory == null ? "active" : "")">Todos</a>
        @foreach (var cat in ViewBag.Categories)
        {
            <a asp-action="Index" asp-route-categoryId="@cat.Id" asp-route-periodId="@Model.CurrentPeriod.Id"
               class="btn btn-outline-primary @(ViewBag.SelectedCategory == cat.Id ? "active" : "")">
                @cat.Name
            </a>
        }
    </div>
</div>

<div class="table-responsive">
    <table class="table table-bordered align-middle text-center">
        <thead class="table-light">
            <tr>
                <th>CODIGO</th>
                <th class="text-start">NOMBRE</th>
                <th>CATEGORÍA</th>
                @foreach (var day in Model.DaysInPeriod)
                {
                    <th style="min-width: 60px;">@day.ToString("dd-MMM")</th>
                }
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>@row.Code</td>
                    <td class="text-start">@row.Name</td>
                    <td><span class="badge bg-info text-dark">@row.CategoryName</span></td>

                    @foreach (var day in Model.DaysInPeriod)
                    {
                        var status = string.IsNullOrEmpty(row.DailyStatus.GetValueOrDefault(day)) ? "X" : row.DailyStatus[day];

                        <td class="attendance-cell"
                            data-opid="@row.OperatorsId"
                            data-date="@day.ToString("yyyy-MM-dd")"
                            data-periodid="@Model.CurrentPeriod.Id"
                            onclick="toggleStatus(this)"
                            style="cursor:pointer; font-weight:bold; user-select:none; @(status != "X" ? "color:red;" : "")">
                            @status
                        </td>
                    }

                    <td>
                        <div class="dropdown-container">
                            <button type="button" class="btn btn-sm btn-light menu-button">
                                <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z" /></svg>
                            </button>
                            <div class="card-menu">
                                <ul class="list">
                                    <li><a asp-action="Edit" asp-route-id="@row.OperatorsId" class="element">Editar</a></li>
                                </ul>
                                <div class="separator"></div>
                                <ul class="list">
                                    <li>
                                        <button type="button" class="element delete border-0 bg-transparent w-100"
                                                data-bs-toggle="modal" data-bs-target="#deleteModal"
                                                data-bs-id="@row.OperatorsId" data-bs-name="@row.Name">
                                            Eliminar
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@* MODAL: NUEVO PERIODO (Corregido para apuntar al controlador de Operarios) *@
<div class="modal fade" id="createPeriodModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Operators" asp-action="CreatePeriod" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Nueva Catorcena</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <input name="Description" class="form-control" placeholder="Ej: 13 al 24 de Abril" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fecha Inicio</label>
                        <input type="date" name="StartDate" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fecha Fin</label>
                        <input type="date" name="EndDate" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Crear y Abrir Periodo</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* MODAL: NUEVO OPERARIO *@
<div class="modal fade" id="createOperatorModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                <div class="modal-header"><h5>Nuevo Operario</h5></div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label>Código</label>
                        <input name="Code" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label>Nombre</label>
                        <input name="Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label>Categoría</label>
                        <select name="CategoryId" class="form-control"
                                asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleStatus(cell) {
            const states = ["X", "PP", "ISS", "INC"];
            let currentStatus = cell.innerText.trim();

            let nextIndex = (states.indexOf(currentStatus) + 1) % states.length;
            let nextStatus = states[nextIndex];

            const opId = cell.getAttribute("data-opid");
            const date = cell.getAttribute("data-date");
            const periodId = cell.getAttribute("data-periodid");

            $.post('/Operators/UpdateAttendance', {
                operatorId: opId,
                date: date,
                status: nextStatus,
                periodId: periodId
            })
            .done(function(data) {
                cell.innerText = nextStatus;
                cell.style.color = (nextStatus === "X") ? "black" : "red";
            })
            .fail(function() {
                alert("Error al guardar la asistencia.");
            });
        }
    </script>
}