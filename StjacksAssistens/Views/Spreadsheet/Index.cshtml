@{
    ViewData["Title"] = "Gestión de Planillas Pro";
}
@* Index para mostrar donde esta todas las planillas *@
<style>
    .glass-header {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        border-radius: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .card-planilla {
        border: none;
        border-radius: 1.5rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
        background: #fff;
    }

        .card-planilla:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.08) !important;
        }

    .icon-box {
        width: 70px;
        height: 70px;
        border-radius: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 1.8rem;
    }

    .btn-action {
        border-radius: 0.8rem;
        padding: 0.6rem 1.5rem;
        font-weight: 600;
        transition: 0.2s;
    }

    .status-badge {
        font-size: 0.7rem;
        padding: 0.4rem 0.8rem;
        border-radius: 2rem;
        background: rgba(0,0,0,0.05);
        color: #666;
    }
</style>

<div class="container-fluid py-4" style="background: #f8f9fa; min-height: 90vh;">
    <div class="glass-header p-4 mb-5 shadow-sm d-flex justify-content-between align-items-center">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item active">Planillas</li>
                </ol>
            </nav>
            <h2 class="fw-bold m-0 text-dark">Nómina de Ausentismo</h2>
            <p class="text-muted mb-0 small">Control administrativo por departamentos operativos.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-action shadow">
            <i class="bi bi-plus-circle me-2"></i>Nueva Planilla General
        </a>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-4">
            <div class="card card-planilla shadow-sm p-4">
                <div class="text-end">
                    <span class="status-badge"><i class="bi bi-circle-fill text-primary me-1"></i> Operativo</span>
                </div>
                <div class="card-body text-center">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-box-seam-fill"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Empaque</h4>
                    <p class="text-muted small mb-4">Gestión de tiempos, bonos y descuentos para el personal de despacho y embalaje.</p>
                    <hr class="opacity-25">
                    <div class="d-grid mt-4">
                        <button class="btn btn-primary btn-action">
                            Gestionar Planilla <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @* <div class="col-md-4">
            <div class="card card-planilla shadow-sm p-4">
                <div class="text-end">
                    <span class="status-badge"><i class="bi bi-circle-fill text-secondary me-1"></i> Operativo</span>
                </div>
                <div class="card-body text-center">
                    <div class="icon-box bg-secondary bg-opacity-10 text-secondary">
                        <i class="bi bi-magic"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Confección</h4>
                    <p class="text-muted small mb-4">Cálculo de planilla para operarios de costura y ensamble de prendas de alta calidad.</p>
                    <hr class="opacity-25">
                    <div class="d-grid mt-4">
                        <button class="btn btn-secondary btn-action text-white" style="background-color: #7209b7; border-color: #7209b7;">
                            Gestionar Planilla <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div> *@
        <div class="col-md-4">
            <div class="card card-planilla shadow-sm p-4">
                <div class="text-end">
                    <span class="status-badge"><i class="bi bi-circle-fill text-secondary me-1"></i> Operativo</span>
                </div>
                <div class="card-body text-center">
                    <div class="icon-box bg-secondary bg-opacity-10 text-secondary">
                        <i class="bi bi-magic"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Confección</h4>
                    <p class="text-muted small mb-4">Cálculo de planilla para operarios de costura y ensamble de prendas de alta calidad.</p>
                    <hr class="opacity-25">
                    <div class="d-grid mt-4">
                        <a asp-controller="Ausentismo"
                           asp-action="ReporteOperarios"
                           asp-route-periodId="@ViewBag.CurrentPeriodId"
                           class="btn btn-secondary btn-action text-white"
                           style="background-color: #7209b7; border-color: #7209b7;">
                            Gestionar Planilla <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>




        <div class="col-md-4">
            <div class="card card-planilla shadow-sm p-4">
                <div class="text-end">
                    <span class="status-badge"><i class="bi bi-circle-fill text-warning me-1"></i> Mantenimiento</span>
                </div>
                <div class="card-body text-center">
                    <div class="icon-box bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-tools"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Mecánicos</h4>
                    <p class="text-muted small mb-4">Control de asistencia y pagos para el equipo técnico de mantenimiento de maquinaria.</p>
                    <hr class="opacity-25">
                    <div class="d-grid mt-4">
                        <a asp-controller="Ausentismo"
                           asp-action="ReporteMecanicos"
                           asp-route-periodId="@Model.PeriodoActualId"
                           class="btn btn-warning btn-action text-dark">
                            Gestionar Planilla <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12 text-center">
            <div class="p-4 rounded-4 bg-white border d-inline-block shadow-sm">
                <span class="text-muted small"><i class="bi bi-info-circle me-2"></i>Los datos se sincronizan automáticamente con el módulo de RRHH cada 15 minutos.</span>
            </div>
        </div>
    </div>
</div>